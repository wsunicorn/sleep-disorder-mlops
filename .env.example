# Biến môi trường — copy file này thành .env và điền giá trị thực

# Django
DJANGO_SECRET_KEY=change-me-in-production-use-secrets-manager
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (AWS RDS PostgreSQL)
DATABASE_URL=postgresql://sleepuser:password@localhost:5432/sleepdb

# Redis (AWS ElastiCache)
REDIS_URL=redis://localhost:6379/0

# AWS
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=ap-southeast-1
S3_BUCKET=sleep-mlops-data

# MLflow (self-hosted trên EC2)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_MODEL_NAME=sleep-disorder-classifier

# MQTT Broker
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX=sleep/sensor
